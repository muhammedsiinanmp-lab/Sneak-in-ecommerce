# ================================================================
# PRODUCTION ENVIRONMENT — Copy this to .env.prod on EC2
# and fill in real values. NEVER commit .env.prod to Git!
# ================================================================

# === Django ===
SECRET_KEY=generate-a-real-50-char-key-here
DJANGO_SETTINGS_MODULE=config.settings.prod

# === Database ===
# Docker PostgreSQL (before RDS migration):
DB_NAME=sneakin_db
DB_USER=sneakin_app
DB_PASSWORD=STRONG_DB_PASSWORD_HERE
DB_HOST=db
DB_PORT=5432
# After RDS migration, change DB_HOST to your RDS endpoint:
# DB_HOST=your-rds-instance.xxxx.ap-south-1.rds.amazonaws.com

# === Application ===
ALLOWED_HOSTS=sneakin.duckdns.org,YOUR_EC2_IP,localhost,127.0.0.1
CORS_ORIGINS=https://sneakin.duckdns.org,https://sneak-in-ecommerce.vercel.app
CSRF_TRUSTED_ORIGINS=https://sneakin.duckdns.org,https://sneak-in-ecommerce.vercel.app

# === Celery / Redis ===
CELERY_BROKER_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:YOUR_REDIS_PASSWORD@redis:6379/2
REDIS_HOST=redis
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# === Flower ===
FLOWER_USER=admin
FLOWER_PASSWORD=STRONG_FLOWER_PASSWORD

# === Email ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=noreply@sneakin.com

# === Monitoring ===
SENTRY_DSN=https://your-sentry-dsn-here

# === Admin Seed ===
ADMIN_EMAIL=admin@sneakin.com
ADMIN_NAME=Admin
ADMIN_PASSWORD=STRONG_ADMIN_PASSWORD
